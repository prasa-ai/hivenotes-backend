# ── Azure Blob Storage ─────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=session-notes

# ── Azure Table Storage (key-value folder mapping) ─────────────────────────────
AZURE_TABLE_CONNECTION_STRING=
AZURE_TABLE_NAME=therapist

# ── Azure Table Storage (user sessions) ──────────────────────────────────────
AZURE_SESSIONS_TABLE_CONNECTION_STRING=
AZURE_SESSIONS_TABLE_NAME=usersession

# ── Azure AI / Whisper + GPT transcript cleaning ──────────────────────────────
AZURE_OPENAI_ENDPOINT=https://oai-hivenotes.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_WHISPER_DEPLOYMENT=whisper

AZURE_GPT_MINI_TRANSCRIBE_ENDPOINT=https://james-mms0vgs8-eastus2.services.ai.azure.com/
AZURE_GPT_MINI_TRANSCRIBE_API_KEY=
AZURE_GPT_MINI_API_VERSION=2025-03-01-preview
AZURE_GPT_MINI_TRANSCRIBE_DEPLOYMENT=gpt-4o-mini-transcribe

# GPT model deployment used for SOAP generation (chat completions)
AZURE_SOAP_ENDPOINT=https://oai-hivenotes.openai.azure.com/
AZURE_SOAP_API_KEY=
AZURE_SOAP_API_VERSION=2024-06-01

# GPT model deployment used for transcript cleaning, SOAP generation (and transcription when Whisper is off)
AZURE_GPT_MINI_DEPLOYMENT=gpt-4o-mini
# Set to true to force Whisper for all transcriptions.
# Future: rate-limiting logic will set this per-request (every 4th+ req/min → Whisper)
USE_WHISPER_TRANSCRIPTION=false
# ── Notifications (Step 8) ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@testhivenotes.com
# Azure Communication Services (email)
AZURE_EMAIL_CONNECTION_STRING=
# Slack — choose webhook (simple) OR bot token (full SDK)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
# ── App settings ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

COSMOS_ENDPOINT={your_cosmos_endpoint}
COSMOS_KEY={your_cosmos_key}
